<mujoco model="2R_robotic_arm">
    <compiler angle="radian" coordinate="local" />
    <option timestep="0.01" gravity="0 0 -9.81" />

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512" />
        <texture name="texgeom" type="cube" builtin="flat" mark="cross" width="127" height="1278" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1" random="0.01" />
        <texture name="texplane" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="512" height="512" />
        
        <material name="geom" texture="texgeom" texuniform="true" />
        <material name="MatPlane" reflectance="0.3" texture="texplane" texrepeat="1 1" texuniform="true" />
        <material name="target_mat" rgba="0 1 0 0.5" />
    </asset>
    
    <worldbody>
        <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
        <geom name="floor" pos="0 0 0" size="0 0 0.05" type="plane" material="MatPlane" condim="3" />

        <body name="base" pos="0 0 0.05">
            <geom type="sphere" size="0.05" rgba="0.7 0.2 0.2 1" />
            
            <body name="link1" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14" damping="0.5"/>
                <geom type="capsule" fromto="0 0 0 0.75 0 0" size="0.04" rgba="0.2 0.2 0.7 1" />
                
                <body name="link2" pos="0.75 0 0">
                    <joint name="joint2" type="hinge" axis="0 0 1" range="-3.14 3.14" damping="0.5"/>
                    <geom type="capsule" fromto="0 0 0 0.5 0 0" size="0.03" rgba="0.2 0.7 0.2 1" />
                    
                    <!-- CHANGED: ee_tip is now a BODY so Pgraph can calculate J for it -->
                    <body name="ee_tip" pos="0.5 0 0">
                        <geom type="sphere" size="0.03" rgba="1 0 0 1" mass="0.01"/>
                    </body>
                </body>
            </body>
        </body>

        <!-- TARGET OBJECT -->
        <body name="target" pos="0.5 0.5 0.05">
            <geom type="sphere" size="0.05" material="target_mat" conaffinity="0" contype="0"/>
        </body>
    </worldbody>

    <actuator>
        <motor name="motor1" joint="joint1" ctrlrange="-50 50" gear="1" />
        <motor name="motor2" joint="joint2" ctrlrange="-50 50" gear="1" />
    </actuator>
</mujoco>